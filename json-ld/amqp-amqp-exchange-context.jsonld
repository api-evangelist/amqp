{
  "@context": {
    "@version": 1.1,
    "amqp": "https://www.amqp.org/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AMQP Exchange": "amqp:AMQP Exchange",
    "name": {
      "@id": "amqp:name",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "amqp:type",
      "@type": "xsd:string"
    },
    "durable": {
      "@id": "amqp:durable",
      "@type": "xsd:boolean"
    },
    "autoDelete": {
      "@id": "amqp:autoDelete",
      "@type": "xsd:boolean"
    },
    "internal": {
      "@id": "amqp:internal",
      "@type": "xsd:boolean"
    },
    "arguments": {
      "@id": "amqp:arguments",
      "@type": "@id"
    }
  }
}